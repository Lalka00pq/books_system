# Настройки подключения к базе данных PostgreSQL
# Формат: postgresql+asyncpg://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=your_database_url_here

SECRET_KEY=your_super_secret_key_for_jwt_tokens_replace_me

# Алгоритм шифрования (например, HS256)
ALGORITHM=your_crypto_algorithm_here

# Время жизни токена авторизации в минутах (например, 120)
ACCESS_TOKEN_EXPIRE_MINUTES=your_token_expiry_time_in_minutes_here
